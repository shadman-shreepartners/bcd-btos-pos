# bcd-japan-integration-service environment variables

# Service
PORT=3004
NODE_ENV=development

# JAL SSO
JAL_SSO_URL=https://example.com/jal-sso
# Identifier used by JAL to recognize the BTOS/BCD SSO integration
JAL_SEAMLESS_ID=your-seamless-id
# Company-specific JAL SSO access code required for login
JAL_ACCESS_CODE=your-access-code
# Admin/service account ID used by JAL for auto-creating travelers during SSO
JAL_ACUD_ID=your-acud-id
# Password for the `acudId` service account used during SSO auto-registration
JAL_ACUD_PASSWORD=your-acud-password

# JAL SOAP — RetrieveProcedure service (see JAL-SOAP-API-Documentation.md)
# WSDL is typically the service URL; confirm with your JAL integration pack.
JAL_SOAP_WSDL_URL=https://example.com/jal-soap/RetrieveProcedure
JAL_SOAP_WSDL_URL=https://example.com/jal-soap/RetrieveProcedure
# Corporate ID for SOAP in0
JAL_SOAP_CORPORATE_ID=your-corporate-id
JAL_SOAP_CORPORATE_ID=your-corporate-id
# Optional HTTP Basic auth (set both or neither)
# JAL_SOAP_BASIC_USER=
# JAL_SOAP_BASIC_PASSWORD=
# Optional: SOAP method name without Async (default getRecordDetailFromProject)
JAL_SOAP_RETRIEVE_OPERATION=getRecordDetailFromProject
# Optional: SOAP HTTP request timeout in milliseconds (default 30000)
# JAL_SOAP_TIMEOUT_MS=30000
