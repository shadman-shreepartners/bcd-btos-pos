# bcd-japan-integration-service environment variables


# Service
PORT=3004
NODE_ENV=development


# ─────────────────────────────────────────────
# JAL SSO
# ─────────────────────────────────────────────

# JAL SSO v2 endpoint — verified working (use this, not the legacy URL)
JAL_SSO_URL=https://example.com/jal-sso
# Legacy SSO endpoint — do not use for new work
# JAL_SSO_LEGACY_URL=https://example.com/jal-sso-legacy

# Fixed SSO identifier issued by JAL to BCD Travel — constant for all BTOS customers
JAL_SEAMLESS_ID=your-seamless-id

# Company-specific SSO access code issued by JAL per customer company
# Stored in WEB_CUSTOMER_USER.JALONLINE_ACCESSCODE
JAL_ACCESS_CODE=your-access-code

# Auto-registration admin user ID — allows JAL to auto-create employee accounts during SSO
# Stored in WEB_CUSTOMER_USER.JALONLINE_ADMIN_USERID
JAL_ACUD_ID=your-acud-id

# Password for the acudId service account used during SSO auto-registration
# Stored in WEB_CUSTOMER_USER.JALONLINE_ADMIN_PASSWD
JAL_ACUD_PASSWORD=your-acud-password


# ─────────────────────────────────────────────
# JAL SOAP — RetrieveProcedure
# ─────────────────────────────────────────────

# RetrieveProcedure endpoint — append ?wsdl for WSDL discovery
JAL_SOAP_WSDL_URL=https://example.com/jal-soap/RetrieveProcedure?wsdl

# Corporate ID sent as in0 in every SOAP request — per company
# Stored in WEB_CUSTOMER_USER.JALONLINE_CORPID
# Example format: C0050870 (max 8 chars)
JAL_SOAP_CORPORATE_ID=your-corporate-id

# SOAP XML namespace — fixed, do not change
# Used by SOAP client for envelope serialization
JAL_SOAP_NAMESPACE=your-soap-namespace

# Primary retrieve operation — use project number as the main lookup key
# PNR-based lookup is unreliable — same booking may return not found by PNR but found by project
# All 7 available operations: getRecordDetail, getRecordDetailFromProject (recommended),
# getRecordDetailFromProjectAndJMB, getRecordDetailFromProjectAndPNR,
# getRecordDetailFromJMBAndPNR, getRecordDetailFromJMBNumber, getRecordDetailFromPNRNumber
JAL_SOAP_RETRIEVE_OPERATION=getRecordDetailFromProject

# SOAP HTTP request timeout in milliseconds (default 30000)
JAL_SOAP_TIMEOUT_MS=30000

# Optional HTTP Basic auth — set both or neither
# JAL_SOAP_BASIC_USER=
# JAL_SOAP_BASIC_PASSWORD=


# ─────────────────────────────────────────────
# Ekispert Route Search
# ─────────────────────────────────────────────

# Server-side API key for Ekispert route search proxy
EKISPERT_API_KEY=your-ekispert-api-key

# Ekispert upstream base URL — use HTTP for this endpoint
EKISPERT_BASE_URL=http://example.com/ekispert


# ─────────────────────────────────────────────
# JAL SOAP — PollingPNR (Phase 2 — batch sync)
# ─────────────────────────────────────────────

# PollingPNR endpoint — WSDL verified but NOT tested end-to-end
# Requires a separate Authority object with its own credentials (see below)
# Use case: poll JAL for all bookings changed within a date range (max 3 months lookback)
# Recommended batch frequency: every 30 minutes
# JAL_SOAP_POLLING_URL=https://example.com/jal-soap/PollingPNR

# PollingPNR Authority credentials — different from RetrieveProcedure credentials
# These are provisioned through an external batch application by JAL
# Current status: corpId identified, remaining values NOT yet located
# Likely location: legacy web.config, encrypted app config, or DB config table
# JAL_POLLING_CORP_ID=your-polling-corp-id
# JAL_POLLING_PASSWORD=       <- NOT YET FOUND — required for PollingPNR Authority
# JAL_POLLING_ID=             <- NOT YET FOUND — required for PollingPNR Authority (prefixed with X)
# JAL_POLLING_FCID=           <- NOT YET FOUND — required for PollingPNR Authority (3 chars)

# Batch sync interval in minutes — used by the scheduled PollingPNR job
# JAL_POLLING_INTERVAL_MINUTES=30

# NOTE: PollingPNR is NOT required for initial rollout.
# The system operates using direct RetrieveProcedure calls after booking.
# PollingPNR enables automatic batch sync and recovery of missed/changed bookings.
# Treat as Phase 2 enhancement — do not block launch on missing Authority credentials.


# ─────────────────────────────────────────────
# JAL — Deprecated (do not use)
# ─────────────────────────────────────────────

# MemberManage SOAP API — DEPRECATED
# JAL now auto-creates employee accounts during SSO login (acudId/acudPassword handles this)
# The MemberManage call site in the legacy codebase is entirely commented out
# Do not re-enable or implement in new BTOS
# JAL_MEMBER_MANAGE_URL=https://example.com/jal-soap/MemberManage


# ─────────────────────────────────────────────
# ANA SSO
# ─────────────────────────────────────────────

# ANA Biz SSO endpoint — fixed for all corporate clients
# Verified reachable (200 OK, Angular SPA loads)
ANA_SSO_URL=https://example.com/ana-sso

# BTOS callback URL posted back by ANA after the employee completes booking
# ANA posts booking XML to this URL after the employee completes the booking flow
# Must be publicly reachable by ANA servers — never override from the frontend
ANA_SEND_DATA_URL=https://example.com/btos/apl/AnaBizPost.aspx

# Per-company SSO credentials — JSON array resolved by companyId + employeeId at request time
# Fields: companyId, employeeId, loginId, loginPw, adminUserId, userId, passwd
# companyManagementCd3 is derived from the projectNumber prefix
# companyId   = WEB_CUSTOMER_USERID from legacy DB
# employeeId  = WEB_CLIENT_USERID from legacy DB
# loginId     = WEB_CUSTOMER_USER.ANABIZ_CORPID
# loginPw     = WEB_CUSTOMER_USER.ANABIZ_PASSWD
# userId      = employee's ANA mileage number
# passwd      = employee's ANA password
ANA_SSO_CREDENTIALS=[{"companyId":"your-company-id","employeeId":"your-employee-id","loginId":"your-login-id","loginPw":"your-login-pw","adminUserId":"","userId":"your-user-id","passwd":"your-passwd"}]
